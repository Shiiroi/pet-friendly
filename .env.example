# Client-safe (Vite bundles anything prefixed VITE_ into the browser --
# only put keys here that are safe for any visitor to see, protected by RLS)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_ENFORCE_GEOFENCE=false


# Server-only -- NEVER prefix with VITE_, NEVER import from anything
# under src/. This key bypasses RLS entirely. Only used in local/CI
# Node scripts (e.g. a seed script), never in the shipped app.
SUPABASE_SERVICE_ROLE_KEY=
